{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "server": "node server.js",
    "desktop": "electron .",
    "build:desktop": "electron-builder",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.fortfruit.deploymanager",
    "productName": "FortFruit Deploy",
    "win": {
      "icon": "assets/hacker.png",
      "target": "portable"
    },
    "directories": {
      "output": "dist_desktop"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "server.js",
      "projects.json",
      "electron.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      "projects.json",
      "preload.cjs"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-scp": "^0.0.25",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "ssh2": "^1.17.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
